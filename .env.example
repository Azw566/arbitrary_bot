# Copy this file to .env and fill in your values. Never commit .env.

# Ethereum RPC endpoints (Infura, Alchemy, etc.)
RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
RPC_URL_FALLBACK=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Wallet (never expose on mainnet — use a dedicated bot wallet)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS

# Deployed contract address (Sepolia testnet by default)
CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS

# PostgreSQL (optional — for opportunity logging)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=arbitrage
DB_USER=postgres
DB_PASSWORD=yourpassword

# Bot config
PROFIT_NET=0.5          # minimum net profit % to trigger execution
GAS_RESERVE_ETH=0.05    # ETH kept aside for gas
