# Copy this file to .env and fill in your values. Never commit .env.

# Ethereum RPC endpoints — use wss:// for WebSocket (recommended, faster block detection)
# For testnet (Sepolia) — start here before going to mainnet
RPC_URL=wss://eth-sepolia.g.alchemy.com/v2/YOUR_SEPOLIA_API_KEY
# For mainnet — swap RPC_URL to this once testnet is validated
RPC_URL_FALLBACK=wss://eth-mainnet.g.alchemy.com/v2/YOUR_MAINNET_API_KEY

# Wallet (never expose on mainnet — use a dedicated bot wallet)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS

# Deployed contract address (Sepolia testnet by default)
CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS

# PostgreSQL (optional — for opportunity logging)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=arbitrage
DB_USER=postgres
DB_PASSWORD=yourpassword

# Bot config
PROFIT_NET=0.5          # minimum net profit % to trigger execution
GAS_RESERVE_ETH=0.05    # ETH kept aside for gas

# MEV Protection — Flashbots relay (optional)
# Set to a hex private key used ONLY to sign bundles for the relay.
# This key does NOT need to hold ETH; it is a bundle-signing identity key.
# Leave unset to use normal (public mempool) transaction submission.
# FLASHBOTS_AUTH_KEY=0xYOUR_FLASHBOTS_SIGNING_KEY
# FLASHBOTS_RELAY_URL=https://relay.flashbots.net  # override relay endpoint
